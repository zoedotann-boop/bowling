# Resend transactional email - used by the contact form and admin login OTP.
# When unset in dev, emails are logged to the server console instead of sent.
# Get an API key at https://resend.com (Dashboard → API Keys).
RESEND_API_KEY=
CONTACT_FROM_EMAIL=no-reply@rgbowling.com

# ---------------------------------------------------------------------------
# Admin authentication (Better Auth + Drizzle + Postgres)
# ---------------------------------------------------------------------------

# Postgres connection string used by Drizzle.
# Local: install Postgres (e.g., `brew install postgresql@16`) and create a DB,
#   then use postgres://postgres:postgres@localhost:5432/bowling
# Hosted: create a project on Neon (https://neon.tech), Supabase
#   (https://supabase.com), or Vercel Marketplace and paste the pooled
#   connection string (keep ?sslmode=require when provided).
DATABASE_URL=

# Better Auth signing secret (min 32 chars, random).
# Generate with:   openssl rand -base64 32
BETTER_AUTH_SECRET=

# Public base URL of this app. No trailing slash.
# Dev: http://localhost:3000
# Prod: https://your-domain.com
BETTER_AUTH_URL=http://localhost:3000

# ---------------------------------------------------------------------------
# Vercel Blob (admin media library)
# ---------------------------------------------------------------------------

# Read/write token for the Vercel Blob store backing /admin/media uploads.
# Create a Blob store in the Vercel dashboard → Storage; the token is shown
# on the store's settings page. Pull locally with: vercel env pull .env.local
BLOB_READ_WRITE_TOKEN=

# ---------------------------------------------------------------------------
# Google Places API (admin reviews sync)
# ---------------------------------------------------------------------------

# API key for Google Places API (New) — used by the daily cron at
# /api/cron/sync-reviews to pull Google reviews per branch.
# Enable "Places API (New)" in Google Cloud Console → APIs & Services,
# then create an API key under Credentials. Restrict it to the Places API
# and (in prod) to your Vercel deployment IPs / referrers.
GOOGLE_PLACES_API_KEY=

# Shared secret for Vercel-scheduled cron routes under /api/cron/*.
# Vercel sends this as `Authorization: Bearer <secret>`; if unset in dev,
# the route allows unauthenticated GET requests for local testing.
# Generate with: openssl rand -base64 32
CRON_SECRET=
