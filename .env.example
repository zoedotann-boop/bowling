# Resend transactional email - used by the contact form.
# When unset in dev, the form will log the inquiry to the server console.
RESEND_API_KEY=
CONTACT_FROM_EMAIL=no-reply@rgbowling.com

# Local-dev branch override (ignored in production). Set to a branch slug
# from lib/branches.ts to preview that branch on localhost.
# BRANCH_OVERRIDE=ramat-gan
