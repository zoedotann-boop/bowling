{
  "name": "bowling",
  "version": "0.0.1",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "bunx eslint . --max-warnings 0",
    "format": "prettier --write \"**/*.{ts,tsx}\"",
    "format:check": "bunx prettier --check .",
    "typecheck": "tsc --noEmit",
    "test": "bunx vitest run --passWithNoTests",
    "knip": "bunx knip",
    "i18n-check": "bun scripts/i18n-check.ts",
    "ci": "bun run lint && bun run format:check && bun run test && bun run knip && bun run i18n-check"
  },
  "dependencies": {
    "@base-ui/react": "^1.4.0",
    "@tabler/icons-react": "^3.41.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "next": "16.1.7",
    "next-intl": "^4.9.1",
    "next-themes": "^0.4.6",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "resend": "^6.12.0",
    "shadcn": "^4.3.0",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.1",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.4",
    "eslint-config-next": "16.1.7",
    "postcss": "^8",
    "postcss-load-config": "^6.0.1",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.3"
  }
}
